NODE_ENV=development
HOST=0.0.0.0
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/leads
META_VERIFY_TOKEN=replace_with_meta_verify_token
N8N_WEBHOOK_URL=https://n8n.example.com/webhook/facebook-leads-ingested
N8N_INTERNAL_AUTH_TOKEN=replace_with_shared_secret
